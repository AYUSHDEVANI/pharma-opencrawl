# LLM API Keys (REQUIRED)
# Get your free Gemini API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=

# Crawler Configuration
CRAWL_FREQUENCY_HOURS=24
MAX_CONCURRENT_CRAWLS=5
USER_AGENT=PharmaIntelBot/1.0

# Target URLs (comma-separated)
TARGET_URLS=https://www.fda.gov/drugs,https://www.ema.europa.eu,https://cdsco.gov.in

# Agent Configuration
AGENT_MODEL=gemini-2.5-flash
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=2000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/pharma_intel.log
